# AURA Cognitive Server Environment Configuration Template
# Copy this file to `.env` and fill in your actual credentials.
# DO NOT commit your `.env` file with actual keys to public version control!

# Server Listening Port
PORT=5000

# Gemini Cognitive API Key (from Google AI Studio)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Twilio Configuration (for SMS Dispatch & Fallback Gateway)
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_PHONE_NUMBER=YOUR_TWILIO_PHONE_NUMBER_HERE

# OpenWeather API Key (for Live Local Weather feeds)
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY_HERE

# Google Maps API Key (for backend geolocation caches & hospital distances)
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Firebase Admin SDK Credentials (for hospital & patient record syncing)
FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID_HERE
FIREBASE_CLIENT_EMAIL=YOUR_FIREBASE_CLIENT_EMAIL_HERE
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_FIREBASE_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
