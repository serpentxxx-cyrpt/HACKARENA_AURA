# AURA Frontend Client Environment Configuration Template
# Copy this file to `.env` in the frontend directory and customize it.

# The HTTP/Socket URL of your hosted backend cognitive server.
# Fallback local default: http://localhost:5000
VITE_API_URL=https://your-aura-backend.onrender.com

# Google Maps Javascript API Key for spatial dashboards & route mapping.
# Fallback local default: A public testing key
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
